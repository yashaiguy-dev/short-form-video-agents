# YT-to-Shorts Pipeline — Configuration
# Copy this file to .env and fill in your keys

# Gathos Image API (required — generates editorial slide images)
# Get your key at https://gathos.com
GATHOS_IMAGE_API_KEY=

# Subtitle emphasis color (optional — default: yellow)
# Options: yellow, red, green, lime, cyan, orange, pink, white, or any #RRGGBB hex
SUBTITLE_EMPHASIS_COLOR=yellow
